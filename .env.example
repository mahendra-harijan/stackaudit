# Day 4 backend configuration

# Supabase project URL (https://<project-ref>.supabase.co)
SUPABASE_URL=

# Supabase service role key (server-only; never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key
RESEND_API_KEY=

# Verified sender for transactional emails, e.g. onboarding@yourdomain.com
LEADS_FROM_EMAIL=
